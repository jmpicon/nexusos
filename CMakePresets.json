{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/dist",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (local development)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NEXUS_ENABLE_TESTS": "ON",
        "NEXUS_ENABLE_ASAN": "ON",
        "NEXUS_ENABLE_UBSAN": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release (production build)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NEXUS_ENABLE_TESTS": "OFF",
        "NEXUS_ENABLE_ASAN": "OFF",
        "NEXUS_ENABLE_UBSAN": "OFF"
      }
    },
    {
      "name": "ci",
      "displayName": "CI / Container build",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "NEXUS_ENABLE_TESTS": "ON",
        "NEXUS_BUILD_CONTAINER": "ON"
      }
    },
    {
      "name": "asan",
      "displayName": "Debug + AddressSanitizer",
      "inherits": "debug",
      "cacheVariables": {
        "NEXUS_ENABLE_ASAN": "ON",
        "NEXUS_ENABLE_UBSAN": "ON"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug",   "configurePreset": "debug",   "jobs": 0 },
    { "name": "release", "configurePreset": "release",  "jobs": 0 },
    { "name": "ci",      "configurePreset": "ci",       "jobs": 4  }
  ],

  "testPresets": [
    {
      "name": "unit",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true },
      "filter": { "include": { "label": "unit" } }
    },
    {
      "name": "integration",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true },
      "filter": { "include": { "label": "integration" } }
    },
    {
      "name": "all",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true }
    }
  ],

  "workflowPresets": [
    {
      "name": "full-build",
      "displayName": "Configure → Build → Test",
      "steps": [
        { "type": "configure", "name": "debug" },
        { "type": "build",     "name": "debug" },
        { "type": "test",      "name": "all"   }
      ]
    },
    {
      "name": "release-build",
      "displayName": "Configure → Build Release",
      "steps": [
        { "type": "configure", "name": "release" },
        { "type": "build",     "name": "release" }
      ]
    }
  ]
}
