masscan
arp-scan
arping
traceroute
mtr
whois
bind9-host
dnsutils

# ── Packet capture ────────────────────────────────────────────────────────────
wireshark
tshark
tcpdump
tcpreplay
tcpflow
libpcap-dev
termshark

# ── Network monitoring ────────────────────────────────────────────────────────
suricata
suricata-update
snort
iftop
nethogs
bandwidthd
darkstat

# ── System monitoring ─────────────────────────────────────────────────────────
