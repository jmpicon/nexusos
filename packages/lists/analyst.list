btop
atop
glances
sysstat
iotop

# ── Log and data analysis ─────────────────────────────────────────────────────
jq
yq
ripgrep
fd-find
gawk
miller

# ── System auditing ───────────────────────────────────────────────────────────
lynis
rkhunter
chkrootkit
aide
auditd
audispd-plugins

# ── Firewall ──────────────────────────────────────────────────────────────────
nftables
iptables
ipset
ethtool

# ── Desktop ───────────────────────────────────────────────────────────────────
