# NexusOS — Forensic package list

# ── Disk forensics ────────────────────────────────────────────────────────────
sleuthkit
dc3dd
dcfldd
gddrescue
testdisk
scalpel
foremost
safecopy
dislocker

# ── Filesystem support ────────────────────────────────────────────────────────
e2fsprogs
ntfs-3g
exfatprogs
btrfs-progs
fatresize
hfsprogs
nilfs-tools

# ── Memory forensics ──────────────────────────────────────────────────────────
# volatility3 is installed via pip3 in post-forensic hook
python3
python3-pip
python3-venv

# ── Malware analysis (static) ─────────────────────────────────────────────────
yara
binwalk
clamav
clamav-daemon
radare2

# ── File analysis ─────────────────────────────────────────────────────────────
libimage-exiftool-perl
ssdeep
afflib-tools
ewf-tools

# ── Hash tools ───────────────────────────────────────────────────────────────
hashdeep

# ── Archive handling ─────────────────────────────────────────────────────────
unrar
7zip
cabextract
libarchive-tools

# ── Integrity ────────────────────────────────────────────────────────────────
aide
tripwire
debsums

# ── Log analysis ─────────────────────────────────────────────────────────────
logwatch
