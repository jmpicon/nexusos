## NexusOS — Base audit rules (common overlay)

# Clear all existing rules
-D
-b 8192
--backlog_wait_time 60000

# Authentication and identity changes
-w /etc/passwd  -p wa -k identity
-w /etc/shadow  -p wa -k identity
-w /etc/group   -p wa -k identity
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers

# Privileged execution
-a always,exit -F arch=b64 -S execve -F euid=0 -F auid>=1000 -F auid!=-1 -k priv_exec

# Module loading
-w /sbin/insmod  -p x -k module
-w /sbin/rmmod   -p x -k module
-w /sbin/modprobe -p x -k module

# Cron
-w /etc/crontab  -p wa -k cron
-w /etc/cron.d/  -p wa -k cron

# Mounts
-a always,exit -F arch=b64 -S mount  -k mount
-a always,exit -F arch=b64 -S umount2 -k mount
